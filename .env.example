# CodeForge Agents — configuration
# Copy this file to `.env` and fill in your key. NEVER commit .env to git!

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# auto = try Groq first, then Ollama, then Tools-Only Mode
# (also accepts: groq | ollama)
LLM_PROVIDER=auto

# Two-model strategy: small fast model routes, big model reasons
ROUTER_MODEL=llama-3.1-8b-instant
AGENT_MODEL=llama-3.3-70b-versatile

# Local fallback — used automatically if Groq fails or hits a rate limit (429).
# For best debugging quality locally, try: ollama pull qwen2.5-coder
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Guardrails
PYTHON_EXEC_TIMEOUT=5
RAG_MIN_SIMILARITY=0.25

# Optional: protect a PUBLIC deployment with a passphrase (empty = open)
APP_PASSWORD=
